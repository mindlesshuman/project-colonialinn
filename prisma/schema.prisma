generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

  
}

model Reservation {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  checkInDate  String
  checkInTime  String
  checkOutDate String
  checkOutTime String
  roomType     String
  duration     String   @default("24")
  price        Float    @default(0)
  guests       Int
  message      String?
  status       String   @default("pending") // pending, confirmed, cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
