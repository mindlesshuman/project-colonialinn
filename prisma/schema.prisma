generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Reservation {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  checkInDate  String
  checkInTime  String
  checkOutDate String
  checkOutTime String
  roomType     String
  guests       Int
  message      String?
  status       String   @default("pending") // pending, confirmed, cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
